generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  Admin
  Manager
  Employee
}

enum Status {
  Active
  Inactive
}

enum CategoryType {
  CSR_ACTIVITY
  CHALLENGE
  ESG_GENERAL
}

enum PolicyStatus {
  Draft
  Active
  Archived
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
}

enum ChallengeStatus {
  Draft
  Active
  UnderReview
  Completed
  Archived
}

enum ChallengeDifficulty {
  Easy
  Medium
  Hard
}

enum SourceType {
  Purchase
  Manufacturing
  Expense
  Fleet
}

enum CalculationMethod {
  Auto
  Manual
}

enum AuditStatus {
  Planned
  InProgress
  Completed
}

enum IssueSeverity {
  Low
  Medium
  High
  Critical
}

enum IssueStatus {
  Open
  InProgress
  Resolved
  Closed
}

enum NotificationType {
  ComplianceIssueRaised
  ApprovalDecision
  PolicyReminder
  BadgeUnlocked
}

enum NotificationChannel {
  InApp
  Email
}

enum RedemptionStatus {
  Pending
  Fulfilled
  Cancelled
}

enum ActivityStatus {
  Draft
  Active
  Completed
  Cancelled
}

// ─── Master Data ──────────────────────────────────────────────────────────────

model Department {
  id                 String  @id @default(cuid())
  name               String
  code               String  @unique
  employeeCount      Int     @default(0)
  status             Status  @default(Active)
  headEmployeeId     String?
  parentDepartmentId String?
  deletedAt          DateTime?

  parent           Department?  @relation("DeptHierarchy", fields: [parentDepartmentId], references: [id])
  children         Department[] @relation("DeptHierarchy")

  employees        Employee[]
  carbonTransactions CarbonTransaction[]
  csrActivities    CSRActivity[]
  audits           Audit[]
  environmentalGoals EnvironmentalGoal[]
  departmentScores DepartmentScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id         String       @id @default(cuid())
  name       String
  type       CategoryType
  status     Status       @default(Active)
  deletedAt  DateTime?

  csrActivities CSRActivity[]
  challenges    Challenge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmissionFactor {
  id              String   @id @default(cuid())
  name            String
  activityType    String
  unit            String
  co2eFactorValue Float
  source          String
  effectiveDate   DateTime
  status          Status   @default(Active)
  deletedAt       DateTime?

  carbonTransactions  CarbonTransaction[]
  productESGProfiles  ProductESGProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductESGProfile {
  id                 String  @id @default(cuid())
  productId          String
  productName        String
  emissionFactorId   String
  sustainabilityNotes String?
  certification      String?
  status             Status  @default(Active)

  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EnvironmentalGoal {
  id            String   @id @default(cuid())
  title         String
  description   String?
  targetMetric  String
  targetValue   Float
  currentValue  Float    @default(0)
  departmentId  String?
  startDate     DateTime
  deadline      DateTime
  status        Status   @default(Active)

  department Department? @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ESGPolicy {
  id            String       @id @default(cuid())
  title         String
  description   String?
  category      String
  version       String       @default("1.0")
  effectiveDate DateTime
  status        PolicyStatus @default(Draft)
  fileUrl       String?

  acknowledgements PolicyAcknowledgement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Badge {
  id          String  @id @default(cuid())
  name        String
  description String?
  unlockRule  Json
  iconUrl     String?
  status      Status  @default(Active)

  employeeBadges EmployeeBadge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reward {
  id             String  @id @default(cuid())
  name           String
  description    String?
  pointsRequired Int
  stock          Int     @default(0)
  status         Status  @default(Active)

  redemptions RewardRedemption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Transactional Data ───────────────────────────────────────────────────────

model Employee {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(Employee)
  departmentId String?
  xp           Int      @default(0)
  points       Int      @default(0)
  joinDate     DateTime @default(now())

  department Department? @relation(fields: [departmentId], references: [id])

  participations       EmployeeParticipation[]
  challengeParticipations ChallengeParticipation[]
  policyAcknowledgements  PolicyAcknowledgement[]
  conductedAudits      Audit[]                @relation("AuditorAudits")
  ownedIssues          ComplianceIssue[]      @relation("IssueOwner")
  approvedParticipations EmployeeParticipation[] @relation("ApprovedBy")
  redemptions          RewardRedemption[]
  notifications        Notification[]
  employeeBadges       EmployeeBadge[]
  activityLogs         ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarbonTransaction {
  id                String            @id @default(cuid())
  departmentId      String
  sourceType        SourceType
  sourceRecordId    String?
  emissionFactorId  String
  quantity          Float
  calculatedCO2e    Float
  calculationMethod CalculationMethod @default(Manual)
  transactionDate   DateTime

  department     Department     @relation(fields: [departmentId], references: [id])
  emissionFactor EmissionFactor @relation(fields: [emissionFactorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CSRActivity {
  id           String         @id @default(cuid())
  title        String
  categoryId   String
  description  String?
  departmentId String?
  startDate    DateTime
  endDate      DateTime?
  status       ActivityStatus @default(Active)

  category       Category                @relation(fields: [categoryId], references: [id])
  department     Department?             @relation(fields: [departmentId], references: [id])
  participations EmployeeParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeParticipation {
  id             String         @id @default(cuid())
  employeeId     String
  csrActivityId  String
  proofFileUrl   String?
  approvalStatus ApprovalStatus @default(Pending)
  pointsEarned   Int            @default(0)
  completionDate DateTime?
  approvedById   String?

  employee    Employee    @relation(fields: [employeeId], references: [id])
  csrActivity CSRActivity @relation(fields: [csrActivityId], references: [id])
  approvedBy  Employee?   @relation("ApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, csrActivityId])
}

model Challenge {
  id               String              @id @default(cuid())
  title            String
  categoryId       String
  description      String?
  xp               Int                 @default(0)
  difficulty       ChallengeDifficulty @default(Medium)
  evidenceRequired Boolean             @default(false)
  deadline         DateTime?
  status           ChallengeStatus     @default(Draft)

  category       Category                 @relation(fields: [categoryId], references: [id])
  participations ChallengeParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChallengeParticipation {
  id             String         @id @default(cuid())
  challengeId    String
  employeeId     String
  progressPercent Int           @default(0)
  proofFileUrl   String?
  approvalStatus ApprovalStatus @default(Pending)
  xpAwarded      Int            @default(0)

  challenge Challenge @relation(fields: [challengeId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([challengeId, employeeId])
}

model PolicyAcknowledgement {
  id             String         @id @default(cuid())
  policyId       String
  employeeId     String
  acknowledgedAt DateTime?
  status         ApprovalStatus @default(Pending)

  policy   ESGPolicy @relation(fields: [policyId], references: [id])
  employee Employee  @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([policyId, employeeId])
}

model Audit {
  id              String      @id @default(cuid())
  title           String
  departmentId    String
  auditorId       String
  scope           String?
  scheduledDate   DateTime
  completedDate   DateTime?
  status          AuditStatus @default(Planned)
  findingsSummary String?

  department       Department        @relation(fields: [departmentId], references: [id])
  auditor          Employee          @relation("AuditorAudits", fields: [auditorId], references: [id])
  complianceIssues ComplianceIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplianceIssue {
  id          String        @id @default(cuid())
  auditId     String?
  title       String
  description String?
  severity    IssueSeverity @default(Medium)
  ownerId     String
  dueDate     DateTime
  status      IssueStatus   @default(Open)
  raisedDate  DateTime      @default(now())

  audit Audit?   @relation(fields: [auditId], references: [id])
  owner Employee @relation("IssueOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DepartmentScore {
  id                 String   @id @default(cuid())
  departmentId       String
  periodStart        DateTime
  periodEnd          DateTime
  environmentalScore Float    @default(0)
  socialScore        Float    @default(0)
  governanceScore    Float    @default(0)
  totalScore         Float    @default(0)

  department Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RewardRedemption {
  id          String           @id @default(cuid())
  employeeId  String
  rewardId    String
  pointsSpent Int
  redeemedAt  DateTime         @default(now())
  status      RedemptionStatus @default(Pending)

  employee Employee @relation(fields: [employeeId], references: [id])
  reward   Reward   @relation(fields: [rewardId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id                  String              @id @default(cuid())
  recipientEmployeeId String
  type                NotificationType
  message             String
  channel             NotificationChannel @default(InApp)
  read                Boolean             @default(false)
  createdAt           DateTime            @default(now())

  recipient Employee @relation(fields: [recipientEmployeeId], references: [id])
}

model OrgESGConfig {
  id                              String  @id @default(cuid())
  environmentalWeight             Int     @default(40)
  socialWeight                    Int     @default(30)
  governanceWeight                Int     @default(30)
  autoEmissionCalculationEnabled  Boolean @default(true)
  evidenceRequirementEnabled      Boolean @default(false)
  badgeAutoAwardEnabled           Boolean @default(true)
  inAppNotificationsEnabled       Boolean @default(true)
  emailNotificationsEnabled       Boolean @default(false)

  updatedAt DateTime @updatedAt
}

model NotificationSetting {
  id               String              @id @default(cuid())
  notificationType NotificationType
  channel          NotificationChannel
  enabled          Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([notificationType, channel], name: "notificationType_channel")
}

model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  actor Employee? @relation(fields: [actorId], references: [id])
}

model EmployeeBadge {
  id         String   @id @default(cuid())
  employeeId String
  badgeId    String
  awardedAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([employeeId, badgeId])
}
